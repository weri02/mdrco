<?xml version="1.0"?>
<rdf:RDF xmlns="http://uoc.edu/knowledgeManagement/mdrco#"
     xml:base="http://uoc.edu/knowledgeManagement/mdrco"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:mdrco="http://uoc.edu/knowledgeManagement/mdrco#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://uoc.edu/knowledgeManagement/mdrco#">
        <owl:versionIRI rdf:resource="http://uoc.edu/knowledgeManagement/1.0.0/mdrco#"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-11</terms:created>
        <terms:creator>Houari Bekkay Boumaza</terms:creator>
        <terms:description xml:lang="en">This ontology models the European catalogue of high-risk medical devices and in vitro diagnostic devices under the regulatory framework of the MDR (EU 2017/745) and IVDR (EU 2017/746) regulations.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">Medical Device Regulatory Catalogue Ontology</terms:title>
        <vann:preferredNamespacePrefix>mdrco</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://uoc.edu/knowledgeManagement/mdrco#</vann:preferredNamespaceUri>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#addressesIncident -->


    <owl:ObjectProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#addressesIncident">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:comment xml:lang="en">Relates a field safety corrective action to the incident that triggered it.</rdfs:comment>
        <rdfs:label xml:lang="en">addresses incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#affectsCountry -->


    <owl:ObjectProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#affectsCountry">
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Country"/>
        <rdfs:comment xml:lang="en">Relates a field safety corrective action to a country where it applies.</rdfs:comment>
        <rdfs:label xml:lang="en">affects country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#hasRisk -->


    <owl:ObjectProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#hasRisk">
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:comment xml:lang="en">Relates an incident to the identified risk according to IMDRF nomenclature.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#hasRiskClass">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:range rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RiskClass"/>
        <rdfs:comment xml:lang="en">Relates a medical device to its regulatory risk class.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#involvedDevice -->


    <owl:ObjectProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#involvedDevice">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:comment xml:lang="en">Relates an incident to the medical device involved.</rdfs:comment>
        <rdfs:label xml:lang="en">involved device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#manufacturedBy -->


    <owl:ObjectProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#manufacturedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:range rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a medical device to its manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">manufactured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#registeredIn -->


    <owl:ObjectProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#registeredIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Manufacturer"/>
        <rdfs:range rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Country"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer to the country where it is registered.</rdfs:comment>
        <rdfs:label xml:lang="en">registered in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#regulatedBy -->


    <owl:ObjectProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#regulatedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:range rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Relates a medical device to its applicable regulatory framework.</rdfs:comment>
        <rdfs:label xml:lang="en">regulated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#reportedBy -->


    <owl:ObjectProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#reportedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates an incident to the manufacturer that reported it.</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#reportedInCountry -->


    <owl:ObjectProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#reportedInCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Country"/>
        <rdfs:comment xml:lang="en">Relates an incident to the country where it was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">reported in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#supervisedBy -->


    <owl:ObjectProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#supervisedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Manufacturer"/>
        <rdfs:range rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#CompetentAuthority"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer to the competent authority that supervises it.</rdfs:comment>
        <rdfs:label xml:lang="en">supervised by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#actionDate -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#actionDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">The date on which the corrective action was initiated.</rdfs:comment>
        <rdfs:label xml:lang="en">action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#authorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#authorizationNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The regulatory authorization number issued to the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#closureDate -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#closureDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">The date on which the corrective action was closed.</rdfs:comment>
        <rdfs:label xml:lang="en">closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#contactEmail -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#contactEmail">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The regulatory contact email address of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#correctiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#correctiveActionTaken">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether a corrective action was taken in response to the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#countryName -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#countryName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Country"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The name of the country.</rdfs:comment>
        <rdfs:label xml:lang="en">country name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#description -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#description">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A textual description of the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#deviceId -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#deviceId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The unique identifier of the medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">device ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#deviceName -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#deviceName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The commercial name of the medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#devicesAffected -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#devicesAffected">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The number or description of devices affected by the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#eudamedFSCARef -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#eudamedFSCARef">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The EUDAMED reference number for the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#eudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#eudamedIncidentRef">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The EUDAMED reference number for the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#eudamedSRN -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#eudamedSRN">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The Single Registration Number assigned by EUDAMED to the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#eventDate -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#eventDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">The date on which the incident event occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#fscaId -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#fscaId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The unique identifier of the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#imdrfCode -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#imdrfCode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The IMDRF nomenclature code for the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#incidentId -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#incidentId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The unique identifier of the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">incident ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#intendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#intendedPurpose">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The intended purpose of the medical device as stated by the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#isActive -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#isActive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device requires an energy source to operate.</rdfs:comment>
        <rdfs:label xml:lang="en">is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#isIVD -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#isIVD">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device is an in vitro diagnostic device.</rdfs:comment>
        <rdfs:label xml:lang="en">is IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#isImplantable -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#isImplantable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device is implantable.</rdfs:comment>
        <rdfs:label xml:lang="en">is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#isReusable -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#isReusable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device is intended for reuse.</rdfs:comment>
        <rdfs:label xml:lang="en">is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#manufacturerName -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#manufacturerName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The official name of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">manufacturer name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#outcome -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#outcome">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The clinical outcome of the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#patientAge -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#patientAge">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">The age of the patient involved in the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#patientSex -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#patientSex">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The sex of the patient involved in the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">patient sex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#probability -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#probability">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The probability of occurrence of the risk (Low, Medium, High).</rdfs:comment>
        <rdfs:label xml:lang="en">probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#reportDate -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#reportDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">The date on which the incident was reported to the competent authority.</rdfs:comment>
        <rdfs:label xml:lang="en">report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#riskId -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#riskId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The unique identifier of the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">risk ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#riskName -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#riskName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The name of the risk according to IMDRF nomenclature.</rdfs:comment>
        <rdfs:label xml:lang="en">risk name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#severity -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#severity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The severity level of the risk (Critical, Serious, Moderate).</rdfs:comment>
        <rdfs:label xml:lang="en">severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#status -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#status">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The current status of the field safety corrective action (Open or Closed).</rdfs:comment>
        <rdfs:label xml:lang="en">status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#udiDI -->


    <owl:DatatypeProperty rdf:about="http://uoc.edu/knowledgeManagement/mdrco#udiDI">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The Unique Device Identifier - Device Identifier.</rdfs:comment>
        <rdfs:label xml:lang="en">UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ActiveDevice -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:comment xml:lang="en">A device whose operation depends on a source of energy.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ActiveImplant -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ImplantableDevice"/>
        <rdfs:comment xml:lang="en">An active device designed to be totally introduced into the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Implant</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ClassA -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ClassA">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RiskClass"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassB"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassC"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassD"/>
        <rdfs:comment xml:lang="en">IVDR risk class A - lowest risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Class A</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ClassB -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ClassB">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RiskClass"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassC"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassD"/>
        <rdfs:comment xml:lang="en">IVDR risk class B - medium risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Class B</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ClassC -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ClassC">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RiskClass"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassD"/>
        <rdfs:comment xml:lang="en">IVDR risk class C - medium-high risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Class C</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ClassD -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ClassD">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RiskClass"/>
        <rdfs:comment xml:lang="en">IVDR risk class D - highest risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Class D</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ClassI -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ClassI">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RiskClass"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassIII"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassIIa"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassIIb"/>
        <rdfs:comment xml:lang="en">MDR risk class I - lowest risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Class I</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ClassIII -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ClassIII">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RiskClass"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassIIa"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassIIb"/>
        <rdfs:comment xml:lang="en">MDR risk class III - highest risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Class III</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ClassIIa -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ClassIIa">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RiskClass"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#ClassIIb"/>
        <rdfs:comment xml:lang="en">MDR risk class IIa - medium risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIa</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ClassIIb -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ClassIIb">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RiskClass"/>
        <rdfs:comment xml:lang="en">MDR risk class IIb - medium-high risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIb</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ClosedFSCA -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ClosedFSCA">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <rdfs:comment xml:lang="en">A field safety corrective action that has a closure date, inferred by SWRL rule</rdfs:comment>
        <rdfs:label xml:lang="en">Closed FSCA</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#CompetentAuthority -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#CompetentAuthority">
        <rdfs:comment xml:lang="en">The national authority responsible for supervising medical device manufacturers in a given country.</rdfs:comment>
        <rdfs:label xml:lang="en">Competent Authority</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#Country -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#Country">
        <rdfs:comment xml:lang="en">A country where a manufacturer is registered or where an incident has been reported.</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://schema.org/Country"/>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#Device -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#manufacturedBy"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A medical device as defined under MDR (EU 2017/745) or IVDR (EU 2017/746) regulations.</rdfs:comment>
        <rdfs:label xml:lang="en">Device</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/ontology/MedicalDevice"/>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#DeviceFailure -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#DeviceFailure">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:comment xml:lang="en">Risk category related to device failure.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Failure</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#DevicePerformance -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#DevicePerformance">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:comment xml:lang="en">Risk category related to suboptimal device performance.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Performance</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#DeviceSafety -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#DeviceSafety">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:comment xml:lang="en">Risk category related to device safety vulnerabilities.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Safety</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#DiagnosticError -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#DiagnosticError">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:comment xml:lang="en">Risk category related to incorrect diagnostic results.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Error</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#EUAuthorizedManufacturer -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#EUAuthorizedManufacturer">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Manufacturer"/>
        <rdfs:comment xml:lang="en">A manufacturer that holds an EU authorization number, inferred by SWRL rule</rdfs:comment>
        <rdfs:label xml:lang="en">EU Authorized Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#addressesIncident"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An action taken to reduce a risk of death or serious deterioration in health associated with a device in use.</rdfs:comment>
        <rdfs:label xml:lang="en">Field Safety Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#HighRiskIncident -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#HighRiskIncident">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:comment xml:lang="en">An incident involving a device classified as Class III, inferred by SWRL rule</rdfs:comment>
        <rdfs:label xml:lang="en">High Risk Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#IVDR -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#IVDR">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RegulatoryFramework"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#MDR"/>
        <rdfs:comment xml:lang="en">In Vitro Diagnostic Regulation EU 2017/746 applicable to IVD devices.</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ImplantableActiveDevice -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:comment xml:lang="en">An active device intended to be totally or partially introduced into the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ImplantableDevice -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:comment xml:lang="en">A device intended to be totally or partially introduced into the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#InSituCorrection -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Recall"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#SafetyAlert"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#UserNotice"/>
        <rdfs:comment xml:lang="en">A FSCA involving correction or modification of the device at its current location.</rdfs:comment>
        <rdfs:label xml:lang="en">In Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:comment xml:lang="en">A device used for examination of specimens derived from the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">In Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#Incident -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#Incident">
        <rdfs:comment xml:lang="en">Any malfunction or deterioration in the characteristics of a device that has led or could lead to patient harm.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#MDR -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#MDR">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Medical Device Regulation EU 2017/745 applicable to general medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">MDR</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#Manufacturer -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#Manufacturer">
        <rdfs:comment xml:lang="en">A natural or legal person responsible for the design and manufacture of a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#NearMissIncident -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#SeriousIncident"/>
        <rdfs:comment xml:lang="en">An incident that could have led to patient harm but did not due to fortunate circumstances.</rdfs:comment>
        <rdfs:label xml:lang="en">Near Miss Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#PatientHarm -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#PatientHarm">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:comment xml:lang="en">Risk category related to direct patient harm.</rdfs:comment>
        <rdfs:label xml:lang="en">Patient Harm</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#ProductQuality -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#ProductQuality">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Risk"/>
        <rdfs:comment xml:lang="en">Risk category related to product quality issues.</rdfs:comment>
        <rdfs:label xml:lang="en">Product Quality</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#Recall -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#Recall">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#SafetyAlert"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#UserNotice"/>
        <rdfs:comment xml:lang="en">A FSCA involving the return of a device to the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#RegulatoryFramework -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#RegulatoryFramework">
        <rdfs:comment xml:lang="en">The European regulatory framework applicable to a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#Risk -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#Risk">
        <rdfs:comment xml:lang="en">A potential hazard associated with a medical device as classified by the IMDRF nomenclature.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#RiskClass -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#RiskClass">
        <rdfs:comment xml:lang="en">The risk classification assigned to a medical device according to MDR or IVDR regulations.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#SafetyAlert -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <owl:disjointWith rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#UserNotice"/>
        <rdfs:comment xml:lang="en">A FSCA involving a safety communication to users and patients.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#SelfTestDevice -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#SelfTestDevice">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#InVitroDiagnosticDevice"/>
        <rdfs:comment xml:lang="en">An IVD device intended to be used by lay persons in a home environment.</rdfs:comment>
        <rdfs:label xml:lang="en">Self Test Device</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#SeriousIncident -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Incident"/>
        <rdfs:comment xml:lang="en">An incident that directly or indirectly led to serious injury or death of a patient.</rdfs:comment>
        <rdfs:label xml:lang="en">Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#SingleUseDevice -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#SingleUseDevice">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Device"/>
        <rdfs:comment xml:lang="en">A device intended to be used on one individual during a single procedure.</rdfs:comment>
        <rdfs:label xml:lang="en">Single Use Device</rdfs:label>
    </owl:Class>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#UserNotice -->


    <owl:Class rdf:about="http://uoc.edu/knowledgeManagement/mdrco#UserNotice">
        <rdfs:subClassOf rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction"/>
        <rdfs:comment xml:lang="en">A FSCA involving a notice sent to device users with corrective instructions.</rdfs:comment>
        <rdfs:label xml:lang="en">User Notice</rdfs:label>
    </owl:Class>
    


