    <!-- http://uoc.edu/knowledgeManagement/mdrco#FSCA-001 -->


    <owl:NamedIndividual rdf:about="http://uoc.edu/knowledgeManagement/mdrco#FSCA-001">
        <rdf:type rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#SafetyAlert"/>
        <addressesIncident rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#INC-001"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-01</actionDate>
        <devicesAffected>850</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000001</eudamedFSCARef>
        <fscaId>FSCA-001</fscaId>
        <status>Open</status>
        <rdfs:comment xml:lang="en">Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA-001</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#FSCA-002 -->


    <owl:NamedIndividual rdf:about="http://uoc.edu/knowledgeManagement/mdrco#FSCA-002">
        <rdf:type rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Recall"/>
