        <devicesAffected>1240</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000002</eudamedFSCARef>
        <fscaId>FSCA-002</fscaId>
        <status>Closed</status>
        <rdfs:comment xml:lang="en">Voluntary recall of affected Micra AV lots due to premature battery depletion. Replacement units provided. 97% of affected devices successfully replaced.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA-002</rdfs:label>
    </owl:NamedIndividual>
    


