    <!-- http://uoc.edu/knowledgeManagement/mdrco#FSCA-009 -->


    <owl:NamedIndividual rdf:about="http://uoc.edu/knowledgeManagement/mdrco#FSCA-009">
        <rdf:type rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#UserNotice"/>
        <addressesIncident rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#INC-011"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-06-20</actionDate>
        <closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-30</closureDate>
        <devicesAffected>620</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000009</eudamedFSCARef>
        <fscaId>FSCA-009</fscaId>
        <status>Closed</status>
        <rdfs:comment xml:lang="en">Customer field notification regarding biotin interference in TSH assay. Updated sample preparation protocol and interference screening algorithm released via software update 4.1.2.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA-009</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#FSCA-010 -->


    <owl:NamedIndividual rdf:about="http://uoc.edu/knowledgeManagement/mdrco#FSCA-010">
        <rdf:type rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Recall"/>
        <addressesIncident rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#INC-012"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-06-30</actionDate>
        <closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-31</closureDate>
        <devicesAffected>12500 tests</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000010</eudamedFSCARef>
        <fscaId>FSCA-010</fscaId>
        <status>Closed</status>
        <rdfs:comment xml:lang="en">Immediate quarantine and replacement of affected reagent lots. Reflex testing protocol issued. All positive results from affected lots to be re-confirmed. New primer design covering BA.2.86 released.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA-010</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#FSCA-011 -->


    <owl:NamedIndividual rdf:about="http://uoc.edu/knowledgeManagement/mdrco#FSCA-011">
        <rdf:type rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#InSituCorrection"/>
        <addressesIncident rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#INC-014"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-01</actionDate>
        <devicesAffected>3200</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000011</eudamedFSCARef>
        <fscaId>FSCA-011</fscaId>
        <status>Open</status>
        <rdfs:comment xml:lang="en">Enhanced calibration protocol issued. Firmware update v1.8.5 mandatory improving temperature compensation algorithm. Patients instructed to perform confirmatory finger-stick at glucose readings &lt;4.5 or &gt;13.9 mmol/L.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA-011</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#FSCA-012 -->


    <owl:NamedIndividual rdf:about="http://uoc.edu/knowledgeManagement/mdrco#FSCA-012">
        <rdf:type rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#Recall"/>
        <addressesIncident rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#INC-015"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-20</actionDate>
        <closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-10-31</closureDate>
        <devicesAffected>2870</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000012</eudamedFSCARef>
        <fscaId>FSCA-012</fscaId>
        <status>Closed</status>
        <rdfs:comment xml:lang="en">Urgent recall and remote software update. Drug library version 4.3.0 deployed correcting decimal point error. All units verified by biomedical engineering before return to clinical use.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA-012</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#FSCA-013 -->


    <owl:NamedIndividual rdf:about="http://uoc.edu/knowledgeManagement/mdrco#FSCA-013">
        <rdf:type rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#SafetyAlert"/>
        <addressesIncident rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#INC-016"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-10</actionDate>
        <devicesAffected>420</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000013</eudamedFSCARef>
        <fscaId>FSCA-013</fscaId>
        <status>Open</status>
        <rdfs:comment xml:lang="en">Safety communication regarding outflow graft kinking risk. Updated surgical technique for graft routing issued. Mandatory follow-up CT at 6 months for patients with affected lot numbers.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA-013</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#FSCA-014 -->


    <owl:NamedIndividual rdf:about="http://uoc.edu/knowledgeManagement/mdrco#FSCA-014">
        <rdf:type rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#UserNotice"/>
        <addressesIncident rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#INC-017"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-25</actionDate>
        <closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-31</closureDate>
        <devicesAffected>1100</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000014</eudamedFSCARef>
        <fscaId>FSCA-014</fscaId>
        <status>Closed</status>
        <rdfs:comment xml:lang="en">Updated IFU regarding post-operative infection prophylaxis protocol. Extended topical antibiotic course (14 days) mandatory post-insertion. Healthcare professionals notified via direct mail and implanting centre visits.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA-014</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://uoc.edu/knowledgeManagement/mdrco#FSCA-015 -->


    <owl:NamedIndividual rdf:about="http://uoc.edu/knowledgeManagement/mdrco#FSCA-015">
        <rdf:type rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#InSituCorrection"/>
        <addressesIncident rdf:resource="http://uoc.edu/knowledgeManagement/mdrco#INC-018"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-10-01</actionDate>
        <devicesAffected>890</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000015</eudamedFSCARef>
        <fscaId>FSCA-015</fscaId>
        <status>Open</status>
        <rdfs:comment xml:lang="en">Security patch 3.0.1 mandatory deployment disabling unrestricted web interface access. Network segmentation guidance issued to hospital IT departments. Penetration test report provided to competent authorities.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA-015</rdfs:label>
    </owl:NamedIndividual>
    


