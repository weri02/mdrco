#    Annotations
#################################################################

:ActiveDevice rdfs:comment "A device whose operation depends on a source of energy."@en ;
              rdfs:label "Active Device"@en .


:ActiveImplant rdfs:comment "An active device designed to be totally introduced into the human body."@en ;
               rdfs:label "Active Implant"@en .


:ImplantableActiveDevice rdfs:comment "An active device intended to be totally or partially introduced into the human body."@en ;
                         rdfs:label "Implantable Active Device"@en .


:ImplantableDevice rdfs:comment "A device intended to be totally or partially introduced into the human body."@en ;
                   rdfs:label "Implantable Device"@en .


:InVitroDiagnosticDevice rdfs:comment "A device used for examination of specimens derived from the human body."@en ;
                         rdfs:label "In Vitro Diagnostic Device"@en .


