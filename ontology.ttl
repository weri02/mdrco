@prefix : <http://uoc.edu/knowledgeManagement/mdrco#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://uoc.edu/knowledgeManagement/mdrco#> .

<http://uoc.edu/knowledgeManagement/mdrco#> rdf:type owl:Ontology ;
                                             owl:versionIRI <http://uoc.edu/knowledgeManagement/1.0.0/mdrco#> ;
                                             <http://purl.org/dc/terms/created> "2026-04-11"^^xsd:date ;
                                             <http://purl.org/dc/terms/creator> "Houari Bekkay Boumaza" ;
                                             <http://purl.org/dc/terms/description> "This ontology models the European catalogue of high-risk medical devices and in vitro diagnostic devices under the regulatory framework of the MDR (EU 2017/745) and IVDR (EU 2017/746) regulations."@en ;
                                             <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                             <http://purl.org/dc/terms/title> "Medical Device Regulatory Catalogue Ontology"@en ;
                                             <http://purl.org/vocab/vann/preferredNamespacePrefix> "mdrco" ;
                                             <http://purl.org/vocab/vann/preferredNamespaceUri> "http://uoc.edu/knowledgeManagement/mdrco#" ;
                                             owl:versionInfo "1.0.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://uoc.edu/knowledgeManagement/mdrco#addressesIncident
:addressesIncident rdf:type owl:ObjectProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain :FieldSafetyCorrectiveAction ;
                   rdfs:range :Incident ;
                   rdfs:comment "Relates a field safety corrective action to the incident that triggered it."@en ;
                   rdfs:label "addresses incident"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#affectsCountry
:affectsCountry rdf:type owl:ObjectProperty ;
                rdfs:domain :FieldSafetyCorrectiveAction ;
                rdfs:range :Country ;
                rdfs:comment "Relates a field safety corrective action to a country where it applies."@en ;
                rdfs:label "affects country"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#affectsDeviceType
:affectsDeviceType rdf:type owl:ObjectProperty ;
                   rdfs:domain :Risk ;
                   rdfs:range :Device ;
                   rdfs:comment "Relates a risk to the type of medical device it affects."@en ;
                   rdfs:label "affects device type"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#hasRisk
:hasRisk rdf:type owl:ObjectProperty ;
         rdfs:domain :Incident ;
         rdfs:range :Risk ;
         rdfs:comment "Relates an incident to the identified risk according to IMDRF nomenclature."@en ;
         rdfs:label "has risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Device ;
              rdfs:range :RiskClass ;
              rdfs:comment "Relates a medical device to its regulatory risk class."@en ;
              rdfs:label "has risk class"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#involvedDevice
:involvedDevice rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :Incident ;
                rdfs:range :Device ;
                rdfs:comment "Relates an incident to the medical device involved."@en ;
                rdfs:label "involved device"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#manufacturedBy
:manufacturedBy rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :Device ;
                rdfs:range :Manufacturer ;
                rdfs:comment "Relates a medical device to its manufacturer."@en ;
                rdfs:label "manufactured by"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#registeredIn
:registeredIn rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range :Country ;
              rdfs:comment "Relates a manufacturer to the country where it is registered."@en ;
              rdfs:label "registered in"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#regulatedBy
:regulatedBy rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Device ;
             rdfs:range :RegulatoryFramework ;
             rdfs:comment "Relates a medical device to its applicable regulatory framework."@en ;
             rdfs:label "regulated by"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#reportedBy
:reportedBy rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:comment "Relates an incident to the manufacturer that reported it."@en ;
            rdfs:label "reported by"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#reportedInCountry
:reportedInCountry rdf:type owl:ObjectProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain :Incident ;
                   rdfs:range :Country ;
                   rdfs:comment "Relates an incident to the country where it was reported."@en ;
                   rdfs:label "reported in country"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#supervisedBy
:supervisedBy rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range :CompetentAuthority ;
              rdfs:comment "Relates a manufacturer to the competent authority that supervises it."@en ;
              rdfs:label "supervised by"@en .


#################################################################
#    Data properties
#################################################################

###  http://uoc.edu/knowledgeManagement/mdrco#actionDate
:actionDate rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :FieldSafetyCorrectiveAction ;
            rdfs:range xsd:date ;
            rdfs:comment "The date on which the corrective action was initiated."@en ;
            rdfs:label "action date"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "The regulatory authorization number issued to the manufacturer."@en ;
                     rdfs:label "authorization number"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#closureDate
:closureDate rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :FieldSafetyCorrectiveAction ;
             rdfs:range xsd:date ;
             rdfs:comment "The date on which the corrective action was closed."@en ;
             rdfs:label "closure date"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#contactEmail
:contactEmail rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string ;
              rdfs:comment "The regulatory contact email address of the manufacturer."@en ;
              rdfs:label "contact email"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#correctiveActionTaken
:correctiveActionTaken rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:boolean ;
                       rdfs:comment "Indicates whether a corrective action was taken in response to the incident."@en ;
                       rdfs:label "corrective action taken"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#countryName
:countryName rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Country ;
             rdfs:range xsd:string ;
             rdfs:comment "The name of the country."@en ;
             rdfs:label "country name"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#description
:description rdf:type owl:DatatypeProperty ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( :FieldSafetyCorrectiveAction
                                         :Incident
                                         :Risk
                                       )
                         ] ;
             rdfs:range xsd:string ;
             rdfs:comment "A textual description of the resource (risk, incident or corrective action)."@en ;
             rdfs:label "description"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#detectionDate
:detectionDate rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:date ;
               rdfs:comment "The date on which the incident was first detected."@en ;
               rdfs:label "detection date"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#deviceId
:deviceId rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:string ;
          rdfs:comment "The unique identifier of the medical device."@en ;
          rdfs:label "device ID"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#deviceName
:deviceName rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:string ;
            rdfs:comment "The commercial name of the medical device."@en ;
            rdfs:label "device name"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#devicesAffected
:devicesAffected rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :FieldSafetyCorrectiveAction ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The number or description of devices affected by the corrective action."@en ;
                 rdfs:label "devices affected"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#eudamedFSCARef
:eudamedFSCARef rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :FieldSafetyCorrectiveAction ;
                rdfs:range xsd:string ;
                rdfs:comment "The EUDAMED reference number for the corrective action."@en ;
                rdfs:label "EUDAMED FSCA reference"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#eudamedIncidentRef
:eudamedIncidentRef rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The EUDAMED reference number for the incident."@en ;
                    rdfs:label "EUDAMED incident reference"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#eudamedSRN
:eudamedSRN rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:string ;
            rdfs:comment "The Single Registration Number assigned by EUDAMED to the manufacturer."@en ;
            rdfs:label "EUDAMED SRN"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#eventDate
:eventDate rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Incident ;
           rdfs:range xsd:date ;
           rdfs:comment "The date on which the incident event occurred."@en ;
           rdfs:label "event date"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#fscaId
:fscaId rdf:type owl:DatatypeProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain :FieldSafetyCorrectiveAction ;
        rdfs:range xsd:string ;
        rdfs:comment "The unique identifier of the field safety corrective action."@en ;
        rdfs:label "FSCA ID"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#imdrfCode
:imdrfCode rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "The IMDRF nomenclature code for the risk."@en ;
           rdfs:label "IMDRF code"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#incidentId
:incidentId rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "The unique identifier of the incident."@en ;
            rdfs:label "incident ID"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#intendedPurpose
:intendedPurpose rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Device ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The intended purpose of the medical device as stated by the manufacturer."@en ;
                 rdfs:label "intended purpose"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#isActive
:isActive rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Indicates whether the device requires an energy source to operate."@en ;
          rdfs:label "is active"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#isIVD
:isIVD rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:boolean ;
       rdfs:comment "Indicates whether the device is an in vitro diagnostic device."@en ;
       rdfs:label "is IVD"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Indicates whether the device is implantable."@en ;
               rdfs:label "is implantable"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#isReusable
:isReusable rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicates whether the device is intended for reuse."@en ;
            rdfs:label "is reusable"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#manufacturerName
:manufacturerName rdf:type owl:DatatypeProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The official name of the manufacturer."@en ;
                  rdfs:label "manufacturer name"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#outcome
:outcome rdf:type owl:DatatypeProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :Incident ;
         rdfs:range xsd:string ;
         rdfs:comment "The clinical outcome of the incident."@en ;
         rdfs:label "outcome"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#patientAge
:patientAge rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:float ;
            rdfs:comment "The age of the patient involved in the incident."@en ;
            rdfs:label "patient age"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#patientSex
:patientSex rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "The sex of the patient involved in the incident."@en ;
            rdfs:label "patient sex"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#probability
:probability rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "The probability of occurrence of the risk (Low, Medium, High)."@en ;
             rdfs:label "probability"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#reportDate
:reportDate rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:date ;
            rdfs:comment "The date on which the incident was reported to the competent authority."@en ;
            rdfs:label "report date"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#riskId
:riskId rdf:type owl:DatatypeProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain :Risk ;
        rdfs:range xsd:string ;
        rdfs:comment "The unique identifier of the risk."@en ;
        rdfs:label "risk ID"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#riskName
:riskName rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:comment "The name of the risk according to IMDRF nomenclature."@en ;
          rdfs:label "risk name"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#scope
:scope rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :FieldSafetyCorrectiveAction ;
       rdfs:range xsd:string ;
       rdfs:comment "The description of devices or lots within the scope of the corrective action."@en ;
       rdfs:label "scope"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#severity
:severity rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:comment "The severity level of the risk (Critical, Serious, Moderate)."@en ;
          rdfs:label "severity"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#status
:status rdf:type owl:DatatypeProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain :FieldSafetyCorrectiveAction ;
        rdfs:range xsd:string ;
        rdfs:comment "The current status of the field safety corrective action (Open or Closed)."@en ;
        rdfs:label "status"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#udiDI
:udiDI rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:string ;
       rdfs:comment "The Unique Device Identifier - Device Identifier."@en ;
       rdfs:label "UDI-DI"@en .


#################################################################
#    Classes
#################################################################

###  http://uoc.edu/knowledgeManagement/mdrco#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :Device .


###  http://uoc.edu/knowledgeManagement/mdrco#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :ImplantableDevice .


###  http://uoc.edu/knowledgeManagement/mdrco#ClassA
:ClassA rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        owl:disjointWith :ClassB ,
                         :ClassC ,
                         :ClassD ;
        rdfs:comment "IVDR risk class A - lowest risk."@en ;
        rdfs:label "Class A"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#ClassB
:ClassB rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        owl:disjointWith :ClassC ,
                         :ClassD ;
        rdfs:comment "IVDR risk class B - medium risk."@en ;
        rdfs:label "Class B"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#ClassC
:ClassC rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        owl:disjointWith :ClassD ;
        rdfs:comment "IVDR risk class C - medium-high risk."@en ;
        rdfs:label "Class C"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#ClassD
:ClassD rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        rdfs:comment "IVDR risk class D - highest risk."@en ;
        rdfs:label "Class D"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#ClassI
:ClassI rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        owl:disjointWith :ClassIII ,
                         :ClassIIa ,
                         :ClassIIb ;
        rdfs:comment "MDR risk class I - lowest risk."@en ;
        rdfs:label "Class I"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#ClassIII
:ClassIII rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass ;
          owl:disjointWith :ClassIIa ,
                           :ClassIIb ;
          rdfs:comment "MDR risk class III - highest risk."@en ;
          rdfs:label "Class III"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#ClassIIa
:ClassIIa rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass ;
          owl:disjointWith :ClassIIb ;
          rdfs:comment "MDR risk class IIa - medium risk."@en ;
          rdfs:label "Class IIa"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#ClassIIb
:ClassIIb rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass ;
          rdfs:comment "MDR risk class IIb - medium-high risk."@en ;
          rdfs:label "Class IIb"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#ClosedFSCA
:ClosedFSCA rdf:type owl:Class ;
            rdfs:subClassOf :FieldSafetyCorrectiveAction ;
            rdfs:comment "A field safety corrective action that has a closure date, inferred by SWRL rule"@en ;
            rdfs:label "Closed FSCA"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#CompetentAuthority
:CompetentAuthority rdf:type owl:Class ;
                    rdfs:comment "The national authority responsible for supervising medical device manufacturers in a given country."@en ;
                    rdfs:label "Competent Authority"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk type related to reagent or device contamination."@en ;
                   rdfs:label "Contamination Risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#Country
:Country rdf:type owl:Class ;
         rdfs:comment "A country where a manufacturer is registered or where an incident has been reported."@en ;
         rdfs:label "Country"@en ;
         rdfs:seeAlso <http://schema.org/Country> .


###  http://uoc.edu/knowledgeManagement/mdrco#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk type related to cybersecurity vulnerabilities in active devices."@en ;
                   rdfs:label "Cybersecurity Risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :manufacturedBy ;
                          owl:cardinality "1"^^xsd:nonNegativeInteger
                        ] ;
        rdfs:comment "A medical device as defined under MDR (EU 2017/745) or IVDR (EU 2017/746) regulations."@en ;
        rdfs:label "Device"@en ;
        rdfs:seeAlso <http://dbpedia.org/ontology/MedicalDevice> .


###  http://uoc.edu/knowledgeManagement/mdrco#DeviceFailure
:DeviceFailure rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Risk category related to device failure."@en ;
               rdfs:label "Device Failure"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#DevicePerformance
:DevicePerformance rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk category related to suboptimal device performance."@en ;
                   rdfs:label "Device Performance"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#DeviceSafety
:DeviceSafety rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Risk category related to device safety vulnerabilities."@en ;
              rdfs:label "Device Safety"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#DiagnosticError
:DiagnosticError rdf:type owl:Class ;
                 rdfs:subClassOf :Risk ;
                 rdfs:comment "Risk category related to incorrect diagnostic results."@en ;
                 rdfs:label "Diagnostic Error"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "Risk type related to incorrect or misleading diagnostic results."@en ;
                rdfs:label "Diagnostic Risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#EUAuthorizedManufacturer
:EUAuthorizedManufacturer rdf:type owl:Class ;
                          rdfs:subClassOf :Manufacturer ;
                          rdfs:comment "A manufacturer that holds an EU authorization number, inferred by SWRL rule"@en ;
                          rdfs:label "EU Authorized Manufacturer"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#FieldSafetyCorrectiveAction
:FieldSafetyCorrectiveAction rdf:type owl:Class ;
                             rdfs:subClassOf [ rdf:type owl:Restriction ;
                                               owl:onProperty :addressesIncident ;
                                               owl:cardinality "1"^^xsd:nonNegativeInteger
                                             ] ;
                             rdfs:comment "An action taken to reduce a risk of death or serious deterioration in health associated with a device in use."@en ;
                             rdfs:label "Field Safety Corrective Action"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#HighRiskIncident
:HighRiskIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident ;
                  rdfs:comment "An incident involving a device classified as Class III, inferred by SWRL rule"@en ;
                  rdfs:label "High Risk Incident"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#IVDR
:IVDR rdf:type owl:Class ;
      rdfs:subClassOf :RegulatoryFramework ;
      owl:disjointWith :MDR ;
      rdfs:comment "In Vitro Diagnostic Regulation EU 2017/746 applicable to IVD devices."@en ;
      rdfs:label "IVDR"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#ImplantableActiveDevice
:ImplantableActiveDevice rdf:type owl:Class ;
                         rdfs:subClassOf :Device .


###  http://uoc.edu/knowledgeManagement/mdrco#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :Device .


###  http://uoc.edu/knowledgeManagement/mdrco#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :FieldSafetyCorrectiveAction ;
                  owl:disjointWith :Recall ,
                                   :SafetyAlert ,
                                   :UserNotice ;
                  rdfs:comment "A FSCA involving correction or modification of the device at its current location."@en ;
                  rdfs:label "In Situ Correction"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :Device .


###  http://uoc.edu/knowledgeManagement/mdrco#Incident
:Incident rdf:type owl:Class ;
          rdfs:comment "Any malfunction or deterioration in the characteristics of a device that has led or could lead to patient harm."@en ;
          rdfs:label "Incident"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#InfectionRisk
:InfectionRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Risk type related to device-associated infection or biofilm."@en ;
               rdfs:label "Infection Risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :Risk ;
            rdfs:comment "Risk type related to physical injury to the patient."@en ;
            rdfs:label "Injury Risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#InterferenceRisk
:InterferenceRisk rdf:type owl:Class ;
                  rdfs:subClassOf :Risk ;
                  rdfs:comment "Risk type related to electromagnetic or device interference."@en ;
                  rdfs:label "Interference Risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#MDR
:MDR rdf:type owl:Class ;
     rdfs:subClassOf :RegulatoryFramework ;
     rdfs:comment "Medical Device Regulation EU 2017/745 applicable to general medical devices."@en ;
     rdfs:label "MDR"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :Risk ;
                 rdfs:comment "Risk type related to device malfunction or functional failure."@en ;
                 rdfs:label "Malfunction Risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:comment "A natural or legal person responsible for the design and manufacture of a medical device."@en ;
              rdfs:label "Manufacturer"@en ;
              rdfs:seeAlso <http://xmlns.com/foaf/0.1/Organization> .


###  http://uoc.edu/knowledgeManagement/mdrco#MaterialRisk
:MaterialRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Risk type related to material degradation, wear debris or toxicity."@en ;
              rdfs:label "Material Risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident ;
                  owl:disjointWith :SeriousIncident ;
                  rdfs:comment "An incident that could have led to patient harm but did not due to fortunate circumstances."@en ;
                  rdfs:label "Near Miss Incident"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#PatientHarm
:PatientHarm rdf:type owl:Class ;
             rdfs:subClassOf :Risk ;
             rdfs:comment "Risk category related to direct patient harm."@en ;
             rdfs:label "Patient Harm"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#ProductQuality
:ProductQuality rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "Risk category related to product quality issues."@en ;
                rdfs:label "Product Quality"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#RadiationRisk
:RadiationRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Risk type related to unintended ionising radiation exposure."@en ;
               rdfs:label "Radiation Risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :FieldSafetyCorrectiveAction ;
        owl:disjointWith :SafetyAlert ,
                         :UserNotice ;
        rdfs:comment "A FSCA involving the return of a device to the manufacturer."@en ;
        rdfs:label "Recall"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#RegulatoryFramework
:RegulatoryFramework rdf:type owl:Class ;
                     rdfs:comment "The European regulatory framework applicable to a medical device."@en ;
                     rdfs:label "Regulatory Framework"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#Risk
:Risk rdf:type owl:Class ;
      rdfs:comment "A potential hazard associated with a medical device as classified by the IMDRF nomenclature."@en ;
      rdfs:label "Risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:comment "The risk classification assigned to a medical device according to MDR or IVDR regulations."@en ;
           rdfs:label "Risk Class"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :FieldSafetyCorrectiveAction ;
             owl:disjointWith :UserNotice ;
             rdfs:comment "A FSCA involving a safety communication to users and patients."@en ;
             rdfs:label "Safety Alert"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#SelfTestDevice
:SelfTestDevice rdf:type owl:Class ;
                rdfs:subClassOf :InVitroDiagnosticDevice ;
                rdfs:comment "An IVD device intended to be used by lay persons in a home environment."@en ;
                rdfs:label "Self Test Device"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident ;
                 rdfs:comment "An incident that directly or indirectly led to serious injury or death of a patient."@en ;
                 rdfs:label "Serious Incident"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#SingleUseDevice
:SingleUseDevice rdf:type owl:Class ;
                 rdfs:subClassOf :Device ;
                 rdfs:comment "A device intended to be used on one individual during a single procedure."@en ;
                 rdfs:label "Single Use Device"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Risk type related to software malfunction or erroneous output."@en ;
              rdfs:label "Software Risk"@en .


###  http://uoc.edu/knowledgeManagement/mdrco#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :FieldSafetyCorrectiveAction ;
            rdfs:comment "A FSCA involving a notice sent to device users with corrective instructions."@en ;
            rdfs:label "User Notice"@en .


